# Server
ANTHROPIC_API_KEY=sk-ant-xxxxx
PORT=3000
WEB_ORIGIN=*                 # set to the deployed web URL in production
RATE_LIMIT_MAX=10            # max chat requests per IP per minute
MAX_OUTPUT_TOKENS=800        # cap per response
DAILY_TOKEN_BUDGET=1000000   # platform-wide daily token backstop (in-memory)
PER_BOT_DAILY_TOKEN_CAP=50000 # per-bot daily token cap (persisted in the DB)

# Database (Postgres)
DATABASE_URL=postgres://postgres@127.0.0.1:5432/interview_bot

# Seed the flagship /u/shay demo bot on startup (only seeds if it is missing)
SEED_DEMO=false

# Platform admins (comma-separated emails) - can see the /admin insights page
ADMIN_EMAILS=shaykopi@gmail.com

# Auth (sessions + "Sign in with LinkedIn" via OpenID Connect)
COOKIE_SECRET=change-me-to-a-long-random-string
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback
