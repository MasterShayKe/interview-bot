{
  "name": "interview-bot",
  "private": true,
  "type": "module",
  "workspaces": ["server", "web"],
  "engines": { "node": ">=20" },
  "overrides": {
    "@types/three": "0.169.0"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "1.31.1"
  },
  "scripts": {
    "build": "npm install --include=dev && npm run build -w @interview-bot/web && npm run build -w @interview-bot/server",
    "start": "npm run start -w @interview-bot/server"
  }
}
